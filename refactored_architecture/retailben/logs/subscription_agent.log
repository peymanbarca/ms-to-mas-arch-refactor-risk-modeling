import json
from datetime import datetime

def filter_subscriptions(subscriptions, current_time):
    # Filter out expired subscriptions
    active_subscriptions = [subscription for subscription in subscriptions if current_time < subscription['expires_at']]
    
    # Sort active subscriptions by discount_percent (highest first)
    sorted_subscriptions = sorted(active_subscriptions, key=lambda x: x['discount_percent'], reverse=True)
    
    # Return only valid JSON
    return json.dumps({
        "active_count": len(sorted_subscriptions),
        "highest_discount": sorted_subscriptions[0]['discount_percent'] if sorted_subscriptions else 0
    })

# Current UTC Time
