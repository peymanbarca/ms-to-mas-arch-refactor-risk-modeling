# Subscriptions to filter
subscriptions = [
    {"_id": "69ff5db279e5dd46d5db225f", "subscription_id": "0dfe65c4-3b0d-40fd-ad4a-8917dda4676a", "user_id": "1", "email": "user@example.com", "promo_code": "SUMMER20", "promo_title": "Summer Sale", "promo_description": "20% off all orders this summer.", "discount_percent": 20.0, "subscribed_at": "2026-05-09 16:15:46.649000", "expires_at": "2026-08-31 23:59:59"},
    # Add more subscriptions here...
]

# Filter and sort subscriptions
result = filter_subscriptions(subscriptions, current_time)

print(result)
```

